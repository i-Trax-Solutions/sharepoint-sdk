{
  "name": "itrax-solutions/sharepoint-sdk",
  "description": "Connect to SharePoint drive with PHP (fork of gwsn/sharepoint-sdk with binary download fix)",
  "license": "MIT",
  "homepage": "https://github.com/i-Trax-Solutions/sharepoint-sdk",
  "keywords": [
    "flysystem",
    "sharepoint",
    "microsoft-graph"
  ],
  "authors": [
    {
      "name": "Global Web Systems B.V.",
      "homepage": "https://www.globalwebsystems.nl",
      "role": "Original Author"
    },
    {
      "name": "i-Trax Solutions Inc.",
      "homepage": "https://www.i-trax.solutions",
      "role": "Fork Maintainer"
    }
  ],
  "require": {
    "php": "^8.0",
    "guzzlehttp/guzzle": "^7.4"
  },
  "replace": {
    "gwsn/sharepoint-sdk": "self.version"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "GWSN\\Microsoft\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "UnitTest\\GWSN\\Microsoft\\": "tests"
    }
  },
  "scripts": {
    "test": [
      "Composer\\Config::disableProcessTimeout",
      "vendor/bin/phpunit"
    ],
    "unit-test": "@test"
  },
  "config": {
    "sort-packages": true
  }
}
